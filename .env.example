# nginx が公開するポート（ホスト側）
PUBLIC_PORT=8080

# ホスト側の検索対象ルート（NASでは /volume1/creative_workspace）
HOST_SEARCH_ROOT=/volume1/creative_workspace

# コンテナ内で許可するディレクトリ（カンマ区切り）
# docker-compose.yml のマウント先と一致させること
ALLOWED_DIRECTORIES=/data/creative_workspace

# クライアントへ返すパスを書き換える（SMBマウント先など）
# 書式: "<container>:<display>" をカンマ区切り
# 例: SMBで /Volumes/creative_workspace にマウントしている場合
DISPLAY_PATH_MAP=/data/creative_workspace:/Volumes/creative_workspace
